# Environment Variables Template for Generative AI Chatbot
# Copy this file to /etc/chatbot/.env and fill in your actual values
# IMPORTANT: Never commit the actual .env file with real secrets to version control!

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Options: 'openai', 'gemini', 'deepseek'
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Google Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# DeepSeek Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# =============================================================================
# Jira Configuration
# =============================================================================
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=PROJ

# =============================================================================
# Confluence Configuration
# =============================================================================
CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=SPACE

# =============================================================================
# MCP (Model Context Protocol) Configuration
# =============================================================================
USE_MCP=true
ENABLE_MCP_TOOLS=true
LAZY_LOAD_TOOLS=true

# =============================================================================
# Memory Management Configuration
# =============================================================================
USE_PERSISTENT_MEMORY=true
MEMORY_DB_PATH=/var/lib/chatbot/data/chatbot_memory.db
MAX_CONTEXT_MESSAGES=50
MEMORY_SUMMARY_THRESHOLD=30

# =============================================================================
# RAG (Retrieval-Augmented Generation) Configuration
# =============================================================================
USE_RAG=true
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_EMBEDDING_MODEL=text-embedding-ada-002
RAG_TOP_K=3
RAG_VECTOR_STORE_PATH=/var/lib/chatbot/data/rag_vectors.db
RAG_ENABLE_CACHE=true
RAG_CACHE_TTL_HOURS=24

# =============================================================================
# Authentication Configuration
# =============================================================================
# IMPORTANT: Change this to a strong random secret in production!
JWT_SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
JWT_EXPIRATION_HOURS=24
AUTH_DB_PATH=/var/lib/chatbot/data/auth.db

# =============================================================================
# Flask Configuration
# =============================================================================
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
ENABLE_DEBUG_LOGGING=false
LOG_FILE=/var/log/chatbot/app.log

# =============================================================================
# Proxy Configuration (if needed)
# =============================================================================
# HTTP_PROXY=
# HTTPS_PROXY=
# GEMINI_PROXY=

# =============================================================================
# Coze Platform Configuration (Optional)
# =============================================================================
COZE_ENABLED=false
COZE_API_TOKEN=
COZE_BOT_ID=
COZE_API_BASE_URL=https://api.coze.com
COZE_API_TIMEOUT=300

# =============================================================================
# Intent Detection Configuration
# =============================================================================
INTENT_USE_LLM=true
INTENT_LLM_TEMPERATURE=0.1
INTENT_CONFIDENCE_THRESHOLD=0.7
INTENT_LLM_TIMEOUT=5.0

# =============================================================================
# Mem0 Advanced Memory (Optional)
# =============================================================================
MEM0_ENABLED=false
# MEM0_USER_ID=
# MEM0_AGENT_ID=chatbot_agent
# MEM0_VECTOR_STORE_PATH=
# MEM0_VECTOR_STORE_PROVIDER=chroma
# MEM0_LLM_MODEL=gpt-3.5-turbo
# MEM0_LLM_PROVIDER=openai

